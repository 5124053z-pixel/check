*.sqlite
*.sqlite3
*.db

# === ログファイル ===
*.log
out.txt

# === エディタ・IDE 設定 ===
.cursor/
.vscode/
.idea/
*.swp
*.swo

# === OS生成ファイル ===
.DS_Store
Thumbs.db

