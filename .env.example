# .env.example — このファイルをコピーして .env を作成してください
# cp .env.example .env
# その後、実際のAPIキーを設定してください

# Google Gemini API Key
# https://aistudio.google.com/app/apikey から取得
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model name (ListModels で利用可能モデルを確認)
GEMINI_MODEL=gemini-2.5-flash

# 公開ドメイン。Caddy がこの名前で HTTPS 証明書を取得します
APP_DOMAIN=vps.ikkyosai.com
